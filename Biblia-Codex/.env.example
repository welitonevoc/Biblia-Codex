# Firebase Configuration
# Obter em: https://console.firebase.google.com/project/seu-projeto/settings/general
VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Google Gemini AI (opcional - para recursos de IA)
# Obter em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=sua_gemini_api_key_aqui
