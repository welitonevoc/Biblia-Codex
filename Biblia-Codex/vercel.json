{
  "buildCommand": "cd Biblia-Codex && npm install && npm run build",
  "outputDirectory": "Biblia-Codex/dist",
  "devCommand": "cd Biblia-Codex && npm run dev",
  "installCommand": "cd Biblia-Codex && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/Biblia-Codex/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}