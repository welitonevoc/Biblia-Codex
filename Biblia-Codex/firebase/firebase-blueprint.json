{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "settings": {
          "type": "object",
          "description": "User's application settings"
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last time the settings were updated" }
      },
      "required": ["uid", "email"]
    },
    "AiCache": {
      "title": "AI Cache",
      "description": "Stores AI-generated explanations to avoid redundant API calls",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The explanation generated by the AI" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the cache was updated" }
      },
      "required": ["content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User settings and profile data"
    },
    "/users/{userId}/aiCache/{cacheKey}": {
      "schema": "AiCache",
      "description": "Cached AI explanations for a specific user"
    }
  }
}
