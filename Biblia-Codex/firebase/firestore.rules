rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - email: string (required) - The user's email address
    //   - displayName: string (optional) - The user's display name
    //   - photoURL: string (optional) - The user's profile picture URL
    //   - settings: map (optional) - User's application settings
    //   - updatedAt: timestamp (optional) - Last time the settings were updated
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;

      match /aiCache/{cacheKey} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
