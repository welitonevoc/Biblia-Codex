#!/usr/bin/env sh

MSG_FILE="$1"

first_non_comment_line() {
  grep -v '^[[:space:]]*#' "$1" | sed -n '1p' | tr -d '\r'
}

lower() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

is_portuguese() {
  line="$(lower "$1")"
  if printf '%s' "$line" | grep -Eq "[????????????]"; then return 0; fi
  if printf '%s' "$line" | grep -Eq "\b(de|da|do|das|dos|para|com|sem|em|no|na|nos|nas|que|como|ajusta|corrige|adiciona|remove|melhora|atualiza|suporte|erro|falha|versao|tela|modulo|importacao|leitura|banco|arquivo|configuracao)\b"; then return 0; fi
  return 1
}

get_type() {
  raw="$(lower "$1")"
  t="$(printf '%s' "$raw" | sed -nE 's/^([a-z]+)(\([^)]+\))?(!)?:.*/\1/p')"
  case "$t" in feat|fix|chore|docs|refactor|test|build|ci|perf|style|revert) printf '%s' "$t";; *) printf '%s' "chore";; esac
}

build_subject() {
  case "$1" in
    feat) printf '%s' "feat: adiciona melhorias no projeto" ;;
    fix) printf '%s' "fix: corrige problemas no projeto" ;;
    docs) printf '%s' "docs: atualiza documentacao do projeto" ;;
    refactor) printf '%s' "refactor: reorganiza codigo do projeto" ;;
    test) printf '%s' "test: ajusta testes do projeto" ;;
    build) printf '%s' "build: atualiza configuracao de build" ;;
    ci) printf '%s' "ci: ajusta fluxo de integracao continua" ;;
    perf) printf '%s' "perf: melhora desempenho do projeto" ;;
    style) printf '%s' "style: ajusta formatacao do codigo" ;;
    revert) printf '%s' "revert: reverte alteracoes anteriores" ;;
    *) printf '%s' "chore: atualiza configuracoes e manutencao" ;;
  esac
}

line="$(first_non_comment_line "$MSG_FILE")"
case "$line" in fixup!*|squash!*) exit 0;; esac

if [ -n "$(printf '%s' "$line" | tr -d '[:space:]')" ] && is_portuguese "$line"; then
  exit 0
fi

type="$(get_type "$line")"
subject="$(build_subject "$type")"
printf '%s\n' "$subject" > "$MSG_FILE"

exit 0
